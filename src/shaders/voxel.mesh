#version 450
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_multiview : enable

layout(local_size_x = 64) in;
layout(triangles, max_vertices = 252, max_primitives = 126) out;

struct MeshChunkInfo {
    vec3 aabb_min;
    uint voxel_slot;
    vec3 aabb_max;
    uint boundary_slot;
};

layout(std430, set = 0, binding = 5) readonly buffer ChunkInfoBuffer {
    MeshChunkInfo chunks[];
};

layout(std430, set = 0, binding = 3) readonly buffer VoxelDataBuffer {
    uint voxel_data[];
};

layout(std430, set = 0, binding = 4) readonly buffer BoundaryDataBuffer {
    uint boundary_data[];
};

layout(set = 0, binding = 1) uniform CameraUBO {
    mat4 view_projection[2];
    mat4 inverse_view_projection[2];
    vec3 light_direction;
    float ambient_strength;
} camera;

layout(push_constant) uniform PushConstants {
    vec4 planes[6];
    vec3 camera_pos;
    uint chunk_count;
    vec2 screen_size;
    uint phase;
    uint opaque_mask;
};

struct MeshPayload {
    uint chunk_index;
    uint sub_chunk_index;
};

taskPayloadSharedEXT MeshPayload payloads[64];

// Fragment shader outputs
layout(location = 0) out vec2 fragTexCoord[];
layout(location = 1) out vec3 fragNormalWorld[];
layout(location = 2) flat out uint fragMaterialId[];
layout(location = 3) out vec3 fragWorldPos[];

shared uint face_counter;

// Face normals: +X, -X, +Y, -Y, +Z, -Z
const vec3 FACE_NORMALS[6] = vec3[6](
    vec3(1, 0, 0), vec3(-1, 0, 0), vec3(0, 1, 0),
    vec3(0, -1, 0), vec3(0, 0, 1), vec3(0, 0, -1)
);

// Tangent and bitangent per face (matches meshing.rs FACES order)
const vec3 FACE_TANGENTS[6] = vec3[6](
    vec3(0, 0, 1), vec3(0, 0, -1), vec3(1, 0, 0),
    vec3(1, 0, 0), vec3(-1, 0, 0), vec3(1, 0, 0)
);

const vec3 FACE_BITANGENTS[6] = vec3[6](
    vec3(0, 1, 0), vec3(0, 1, 0), vec3(0, 0, 1),
    vec3(0, 0, -1), vec3(0, 1, 0), vec3(0, 1, 0)
);

const vec2 CORNER_UVS[4] = vec2[4](
    vec2(0, 1), vec2(1, 1), vec2(1, 0), vec2(0, 0)
);

uint read_block(uint voxel_slot, uint x, uint y, uint z) {
    uint idx = x + z * 16u + y * 256u;
    uint word = voxel_data[voxel_slot * 1024u + idx / 4u];
    return (word >> ((idx % 4u) * 8u)) & 0xFFu;
}

uint read_boundary(uint boundary_slot, uint face, uint u, uint v) {
    uint idx = face * 256u + u + v * 16u;
    uint word = boundary_data[boundary_slot * 384u + idx / 4u];
    return (word >> ((idx % 4u) * 8u)) & 0xFFu;
}

bool is_opaque_block(uint block_type) {
    return (opaque_mask & (1u << block_type)) != 0u;
}

// Determine if face should be emitted (matches meshing.rs should_emit_face)
bool should_emit(uint block, uint neighbor) {
    if (is_opaque_block(block)) return !is_opaque_block(neighbor);
    if (block == 4u) return neighbor == 0u;  // Water adjacent to Air
    return false;
}

uint get_neighbor(uint voxel_slot, uint boundary_slot, int x, int y, int z, uint face) {
    if (x >= 0 && x < 16 && y >= 0 && y < 16 && z >= 0 && z < 16) {
        return read_block(voxel_slot, uint(x), uint(y), uint(z));
    }
    // Read from boundary data
    // Map the out-of-bounds coordinate to boundary (u, v)
    uint bu, bv;
    if (face == 0u) { bu = uint(z); bv = uint(y); }       // +X: neighbor x=0
    else if (face == 1u) { bu = uint(z); bv = uint(y); }   // -X: neighbor x=15
    else if (face == 2u) { bu = uint(x); bv = uint(z); }   // +Y: neighbor y=0
    else if (face == 3u) { bu = uint(x); bv = uint(z); }   // -Y: neighbor y=15
    else if (face == 4u) { bu = uint(x); bv = uint(y); }   // +Z: neighbor z=0
    else { bu = uint(x); bv = uint(y); }                    // -Z: neighbor z=15
    return read_boundary(boundary_slot, face, bu, bv);
}

void emit_face(uint slot, vec3 center, uint face, uint material_id) {
    vec3 n = FACE_NORMALS[face];
    vec3 t = FACE_TANGENTS[face];
    vec3 b = FACE_BITANGENTS[face];
    vec3 face_center = center + n * 0.5;

    uint vi = slot * 4u;
    uint pi = slot * 2u;

    // 4 corners: (-0.5,-0.5), (0.5,-0.5), (0.5,0.5), (-0.5,0.5)
    const float offsets[4] = float[4](-0.5, 0.5, 0.5, -0.5);

    for (uint c = 0u; c < 4u; c++) {
        float u_off = (c == 0u || c == 3u) ? -0.5 : 0.5;
        float v_off = (c < 2u) ? -0.5 : 0.5;
        vec3 world_pos = face_center + t * u_off + b * v_off;

        gl_MeshVerticesEXT[vi + c].gl_Position =
            camera.view_projection[gl_ViewIndex] * vec4(world_pos, 1.0);
        fragWorldPos[vi + c] = world_pos;
        fragTexCoord[vi + c] = CORNER_UVS[c];
        fragNormalWorld[vi + c] = n;
        fragMaterialId[vi + c] = material_id;
    }

    gl_PrimitiveTriangleIndicesEXT[pi]     = uvec3(vi, vi + 1u, vi + 2u);
    gl_PrimitiveTriangleIndicesEXT[pi + 1u] = uvec3(vi, vi + 2u, vi + 3u);
}

void main() {
    MeshPayload payload = payloads[gl_WorkGroupID.x];
    MeshChunkInfo chunk = chunks[payload.chunk_index];

    uint sub_idx = payload.sub_chunk_index;
    uint sx = (sub_idx & 3u) * 4u;
    uint sy = ((sub_idx >> 2u) & 3u) * 4u;
    uint sz = ((sub_idx >> 4u) & 3u) * 4u;

    uint tid = gl_LocalInvocationID.x;
    if (tid == 0u) face_counter = 0u;
    barrier();

    // 64 threads, 64 blocks in 4x4x4 sub-chunk
    uint lx = tid & 3u;
    uint ly = (tid >> 2u) & 3u;
    uint lz = (tid >> 4u) & 3u;

    uint gx = sx + lx;
    uint gy = sy + ly;
    uint gz = sz + lz;

    uint block = read_block(chunk.voxel_slot, gx, gy, gz);

    if (block != 0u) {
        vec3 center = chunk.aabb_min + vec3(float(gx) + 0.5, float(gy) + 0.5, float(gz) + 0.5);

        for (uint face = 0u; face < 6u; face++) {
            ivec3 ndir = ivec3(FACE_NORMALS[face]);
            int nx = int(gx) + ndir.x;
            int ny = int(gy) + ndir.y;
            int nz = int(gz) + ndir.z;

            uint neighbor = get_neighbor(chunk.voxel_slot, chunk.boundary_slot, nx, ny, nz, face);

            if (should_emit(block, neighbor)) {
                uint slot = atomicAdd(face_counter, 1u);
                if (slot < 63u) {
                    emit_face(slot, center, face, block);
                }
            }
        }
    }

    barrier();
    if (tid == 0u) {
        uint final_count = min(face_counter, 63u);
        SetMeshOutputsEXT(final_count * 4u, final_count * 2u);
    }
}
