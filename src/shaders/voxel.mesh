#version 450
#extension GL_EXT_mesh_shader : require
#extension GL_EXT_multiview : enable

layout(local_size_x = 64) in;
layout(triangles, max_vertices = 252, max_primitives = 126) out;

struct MeshChunkInfo {
    vec3 aabb_min;
    uint voxel_slot;
    vec3 aabb_max;
    uint boundary_slot;
};

layout(std430, set = 0, binding = 5) readonly buffer ChunkInfoBuffer {
    MeshChunkInfo chunks[];
};

layout(std430, set = 0, binding = 3) readonly buffer VoxelDataBuffer {
    uint voxel_data[];
};

layout(std430, set = 0, binding = 4) readonly buffer BoundaryDataBuffer {
    uint boundary_data[];
};

layout(set = 0, binding = 1) uniform CameraUBO {
    mat4 view_projection[2];
    mat4 inverse_view_projection[2];
    vec3 light_direction;
    float ambient_strength;
} camera;

layout(push_constant) uniform PushConstants {
    vec4 planes[6];
    vec3 camera_pos;
    uint chunk_count;
    vec2 screen_size;
    uint phase;
    uint opaque_mask;
};

struct MeshPayload {
    uint chunk_index;
    uint sub_chunk_index;
};

taskPayloadSharedEXT MeshPayload payloads[64];

// Fragment shader outputs
layout(location = 0) out vec2 fragTexCoord[];
layout(location = 1) out vec3 fragNormalWorld[];
layout(location = 2) flat out uint fragMaterialId[];
layout(location = 3) out vec3 fragWorldPos[];

// Shared memory for greedy merge results
struct MergedQuad {
    uint face;       // 0-5
    uint material;
    uint u0, v0;     // min corner in face-local 2D
    uint u1, v1;     // max corner (exclusive)
    uint depth;      // position along face normal axis within sub-chunk
};

shared MergedQuad merged_quads[126]; // max primitives / 2
shared uint quad_count;

// Face normals: +X, -X, +Y, -Y, +Z, -Z
const vec3 FACE_NORMALS[6] = vec3[6](
    vec3(1, 0, 0), vec3(-1, 0, 0), vec3(0, 1, 0),
    vec3(0, -1, 0), vec3(0, 0, 1), vec3(0, 0, -1)
);

const vec3 FACE_TANGENTS[6] = vec3[6](
    vec3(0, 0, 1), vec3(0, 0, -1), vec3(1, 0, 0),
    vec3(1, 0, 0), vec3(-1, 0, 0), vec3(1, 0, 0)
);

const vec3 FACE_BITANGENTS[6] = vec3[6](
    vec3(0, 1, 0), vec3(0, 1, 0), vec3(0, 0, 1),
    vec3(0, 0, -1), vec3(0, 1, 0), vec3(0, 1, 0)
);

uint read_block(uint voxel_slot, uint x, uint y, uint z) {
    uint idx = x + z * 16u + y * 256u;
    uint word = voxel_data[voxel_slot * 1024u + idx / 4u];
    return (word >> ((idx % 4u) * 8u)) & 0xFFu;
}

uint read_boundary(uint boundary_slot, uint face, uint u, uint v) {
    uint idx = face * 256u + u + v * 16u;
    uint word = boundary_data[boundary_slot * 384u + idx / 4u];
    return (word >> ((idx % 4u) * 8u)) & 0xFFu;
}

bool is_opaque_block(uint block_type) {
    return (opaque_mask & (1u << block_type)) != 0u;
}

bool should_emit(uint block, uint neighbor) {
    if (is_opaque_block(block)) return !is_opaque_block(neighbor);
    if (block == 4u) return neighbor == 0u;
    return false;
}

uint get_neighbor(uint voxel_slot, uint boundary_slot, int x, int y, int z, uint face) {
    if (x >= 0 && x < 16 && y >= 0 && y < 16 && z >= 0 && z < 16) {
        return read_block(voxel_slot, uint(x), uint(y), uint(z));
    }
    uint bu, bv;
    if (face == 0u) { bu = uint(z); bv = uint(y); }
    else if (face == 1u) { bu = uint(z); bv = uint(y); }
    else if (face == 2u) { bu = uint(x); bv = uint(z); }
    else if (face == 3u) { bu = uint(x); bv = uint(z); }
    else if (face == 4u) { bu = uint(x); bv = uint(y); }
    else { bu = uint(x); bv = uint(y); }
    return read_boundary(boundary_slot, face, bu, bv);
}

// Convert face-local (u, v, depth) back to chunk-local (x, y, z)
ivec3 face_to_chunk(uint face, uint u, uint v, uint d) {
    switch (face) {
        case 0u: return ivec3(d, v, u);     // +X: tangent=Z, bitangent=Y
        case 1u: return ivec3(d, v, u);     // -X: tangent=-Z, bitangent=Y (same mapping)
        case 2u: return ivec3(u, d, v);     // +Y: tangent=X, bitangent=Z
        case 3u: return ivec3(u, d, v);     // -Y: tangent=X, bitangent=-Z
        case 4u: return ivec3(u, v, d);     // +Z: tangent=-X, bitangent=Y (u maps to X)
        default: return ivec3(u, v, d);     // -Z: tangent=X, bitangent=Y
    }
}

// Greedy merge a 4x4 face slice for one face direction at one depth.
// Each thread handles one (face, depth) combo. Writes merged quads to shared memory.
// Uses a 16-bit mask (4x4 grid) per material, scanning rows for mergeable runs.
void greedy_merge_slice(uint voxel_slot, uint boundary_slot,
                        uint face, uint sx, uint sy, uint sz, uint local_depth) {
    // Build per-cell material + visibility for this 4x4 slice
    uint vis_material[4][4]; // [v][u] = material if visible, 0 if not

    uint depth_in_chunk;
    switch (face) {
        case 0u: case 1u: depth_in_chunk = sx + local_depth; break;
        case 2u: case 3u: depth_in_chunk = sy + local_depth; break;
        default:          depth_in_chunk = sz + local_depth; break;
    }

    for (uint v = 0u; v < 4u; v++) {
        for (uint u = 0u; u < 4u; u++) {
            ivec3 pos = face_to_chunk(face, sx + u, sy + v, depth_in_chunk);
            // Remap: for faces 2,3 the v-axis maps differently
            switch (face) {
                case 0u: pos = ivec3(depth_in_chunk, sy + v, sz + u); break;
                case 1u: pos = ivec3(depth_in_chunk, sy + v, sz + u); break;
                case 2u: pos = ivec3(sx + u, depth_in_chunk, sz + v); break;
                case 3u: pos = ivec3(sx + u, depth_in_chunk, sz + v); break;
                case 4u: pos = ivec3(sx + u, sy + v, depth_in_chunk); break;
                default: pos = ivec3(sx + u, sy + v, depth_in_chunk); break;
            }

            uint block = read_block(voxel_slot, uint(pos.x), uint(pos.y), uint(pos.z));
            ivec3 ndir = ivec3(FACE_NORMALS[face]);
            int nx = pos.x + ndir.x;
            int ny = pos.y + ndir.y;
            int nz = pos.z + ndir.z;
            uint neighbor = get_neighbor(voxel_slot, boundary_slot, nx, ny, nz, face);

            if (should_emit(block, neighbor)) {
                vis_material[v][u] = block;
            } else {
                vis_material[v][u] = 0u;
            }
        }
    }

    // Greedy merge: scan rows, extend rectangles downward
    bool used[4][4];
    for (uint v = 0u; v < 4u; v++)
        for (uint u = 0u; u < 4u; u++)
            used[v][u] = false;

    for (uint v = 0u; v < 4u; v++) {
        for (uint u = 0u; u < 4u; u++) {
            uint mat = vis_material[v][u];
            if (mat == 0u || used[v][u]) continue;

            // Extend right
            uint u_end = u + 1u;
            while (u_end < 4u && vis_material[v][u_end] == mat && !used[v][u_end]) {
                u_end++;
            }

            // Extend down
            uint v_end = v + 1u;
            while (v_end < 4u) {
                bool row_ok = true;
                for (uint cu = u; cu < u_end; cu++) {
                    if (vis_material[v_end][cu] != mat || used[v_end][cu]) {
                        row_ok = false;
                        break;
                    }
                }
                if (!row_ok) break;
                v_end++;
            }

            // Mark used
            for (uint cv = v; cv < v_end; cv++)
                for (uint cu = u; cu < u_end; cu++)
                    used[cv][cu] = true;

            // Emit merged quad
            uint slot = atomicAdd(quad_count, 1u);
            if (slot < 126u) {
                merged_quads[slot].face = face;
                merged_quads[slot].material = mat;
                merged_quads[slot].u0 = u;
                merged_quads[slot].v0 = v;
                merged_quads[slot].u1 = u_end;
                merged_quads[slot].v1 = v_end;
                merged_quads[slot].depth = local_depth;
            }
        }
    }
}

void emit_merged_quad(uint slot, MergedQuad q, vec3 aabb_min, uint sx, uint sy, uint sz) {
    vec3 n = FACE_NORMALS[q.face];
    vec3 t = FACE_TANGENTS[q.face];
    vec3 b = FACE_BITANGENTS[q.face];

    // Compute depth position in chunk coordinates
    uint depth_in_chunk;
    switch (q.face) {
        case 0u: case 1u: depth_in_chunk = sx + q.depth; break;
        case 2u: case 3u: depth_in_chunk = sy + q.depth; break;
        default:          depth_in_chunk = sz + q.depth; break;
    }

    // Center of the quad along the face normal axis
    float d_center = float(depth_in_chunk) + 0.5;

    // Quad extents in tangent/bitangent space (in sub-chunk-local coords, offset by sx/sy/sz)
    float u_start, v_start, u_size, v_size;
    switch (q.face) {
        case 0u: u_start = float(sz + q.u0); v_start = float(sy + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
        case 1u: u_start = float(sz + q.u0); v_start = float(sy + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
        case 2u: u_start = float(sx + q.u0); v_start = float(sz + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
        case 3u: u_start = float(sx + q.u0); v_start = float(sz + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
        case 4u: u_start = float(sx + q.u0); v_start = float(sy + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
        default: u_start = float(sx + q.u0); v_start = float(sy + q.v0);
                 u_size = float(q.u1 - q.u0); v_size = float(q.v1 - q.v0); break;
    }

    // Face center in world space
    vec3 face_origin = aabb_min + n * (d_center + 0.5);

    // Four corners of the merged quad
    vec3 corner00 = face_origin + t * u_start + b * v_start;
    vec3 corner10 = face_origin + t * (u_start + u_size) + b * v_start;
    vec3 corner11 = face_origin + t * (u_start + u_size) + b * (v_start + v_size);
    vec3 corner01 = face_origin + t * u_start + b * (v_start + v_size);

    uint vi = slot * 4u;
    uint pi = slot * 2u;

    // UV coordinates scale with quad size for tiling
    vec2 uv00 = vec2(0.0, v_size);
    vec2 uv10 = vec2(u_size, v_size);
    vec2 uv11 = vec2(u_size, 0.0);
    vec2 uv01 = vec2(0.0, 0.0);

    gl_MeshVerticesEXT[vi + 0u].gl_Position = camera.view_projection[gl_ViewIndex] * vec4(corner00, 1.0);
    gl_MeshVerticesEXT[vi + 1u].gl_Position = camera.view_projection[gl_ViewIndex] * vec4(corner10, 1.0);
    gl_MeshVerticesEXT[vi + 2u].gl_Position = camera.view_projection[gl_ViewIndex] * vec4(corner11, 1.0);
    gl_MeshVerticesEXT[vi + 3u].gl_Position = camera.view_projection[gl_ViewIndex] * vec4(corner01, 1.0);

    fragWorldPos[vi + 0u] = corner00;
    fragWorldPos[vi + 1u] = corner10;
    fragWorldPos[vi + 2u] = corner11;
    fragWorldPos[vi + 3u] = corner01;

    fragTexCoord[vi + 0u] = uv00;
    fragTexCoord[vi + 1u] = uv10;
    fragTexCoord[vi + 2u] = uv11;
    fragTexCoord[vi + 3u] = uv01;

    fragNormalWorld[vi + 0u] = n;
    fragNormalWorld[vi + 1u] = n;
    fragNormalWorld[vi + 2u] = n;
    fragNormalWorld[vi + 3u] = n;

    fragMaterialId[vi + 0u] = q.material;
    fragMaterialId[vi + 1u] = q.material;
    fragMaterialId[vi + 2u] = q.material;
    fragMaterialId[vi + 3u] = q.material;

    gl_PrimitiveTriangleIndicesEXT[pi]     = uvec3(vi, vi + 1u, vi + 2u);
    gl_PrimitiveTriangleIndicesEXT[pi + 1u] = uvec3(vi, vi + 2u, vi + 3u);
}

void main() {
    MeshPayload payload = payloads[gl_WorkGroupID.x];
    MeshChunkInfo chunk = chunks[payload.chunk_index];

    uint sub_idx = payload.sub_chunk_index;
    uint sx = (sub_idx & 3u) * 4u;
    uint sy = ((sub_idx >> 2u) & 3u) * 4u;
    uint sz = ((sub_idx >> 4u) & 3u) * 4u;

    uint tid = gl_LocalInvocationID.x;

    // === Pass 1: Greedy merge all face slices ===
    // 6 faces * 4 depths = 24 slices per sub-chunk. 64 threads handle these.
    if (tid == 0u) quad_count = 0u;
    barrier();

    // Each thread handles up to one (face, depth) slice
    // 24 slices total, threads 0-23 each handle one
    if (tid < 24u) {
        uint face = tid / 4u;
        uint depth = tid % 4u;
        greedy_merge_slice(chunk.voxel_slot, chunk.boundary_slot, face, sx, sy, sz, depth);
    }
    barrier();

    // === Pass 2: Emit merged quads ===
    uint clamped = min(quad_count, 63u);
    SetMeshOutputsEXT(clamped * 4u, clamped * 2u);

    if (tid < clamped) {
        emit_merged_quad(tid, merged_quads[tid], chunk.aabb_min, sx, sy, sz);
    }
}
