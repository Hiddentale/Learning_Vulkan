# Simple pyramid (4 triangular faces + square base)
# 5 vertices, 6 triangles

v  0.0  0.5  0.0
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5 -0.5 -0.5
v -0.5 -0.5 -0.5

vt 0.5 0.0
vt 0.0 1.0
vt 1.0 1.0
vt 0.5 0.5

# Front face
f 1/1 3/3 2/2
# Right face
f 1/1 4/3 3/2
# Back face
f 1/1 5/3 4/2
# Left face
f 1/1 2/3 5/2
# Base (two triangles, facing downward)
f 2/4 3/3 4/2
f 2/4 4/2 5/1
